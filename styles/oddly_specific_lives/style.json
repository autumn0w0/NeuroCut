{
  "style_name": "OddlySpecificLives",
  "version": "1.0",
  "category": "POV Storytelling",
  "description": "Immersive first-person life simulation videos with nostalgic, oddly calming, and emotionally reflective storytelling.",
  "content_type": "Faceless Cinematic AI Videos",

  "core_identity": {
    "narrative_style": "first_person",
    "viewer_role": "main_character",
    "immersion_level": "high",
    "emotional_feel": [
      "nostalgic",
      "melancholic",
      "calm",
      "existential",
      "immersive"
    ],
    "tone": "soft spoken cinematic narration"
  },

  "topics": [
    "oddly specific professions",
    "historical lifestyles",
    "fictional mundane realities",
    "daily routines",
    "survival scenarios",
    "retro lifestyles",
    "working class stories",
    "forgotten jobs",
    "alternate reality lives",
    "medieval lifestyles",
    "future dystopian jobs"
  ],

  "title_patterns": [
    "Your Life as a _____",
    "A Day in the Life of a _____",
    "POV: You Are a _____",
    "Living as a _____ in _____",
    "The Daily Life of a _____"
  ],

  "hook_style": {
    "type": "instant immersion",
    "length_seconds": 5,
    "pattern": [
      "direct POV statement",
      "sensory description",
      "immediate situation"
    ],
    "examples": [
      "You wake up before sunrise.",
      "The smell of burning bread fills the room.",
      "Your hands are already covered in flour."
    ]
  },

  "story_structure": {
    "intro": {
      "duration_percent": 10,
      "purpose": "instant immersion into daily life"
    },

    "daily_routine": {
      "duration_percent": 50,
      "purpose": "show repetitive and realistic life moments"
    },

    "emotional_shift": {
      "duration_percent": 25,
      "purpose": "introduce reflection, loneliness, pressure, or realization"
    },

    "ending": {
      "duration_percent": 15,
      "purpose": "quiet emotional conclusion or loop ending"
    }
  },

  "script_style": {
    "sentence_length": "short_to_medium",
    "narration_speed": "slow",
    "dialogue_amount": "minimal",
    "descriptive_density": "high",
    "sensory_focus": true,
    "inner_monologue": true,
    "writing_style": [
      "show don't tell",
      "cinematic narration",
      "environment-focused",
      "emotion through routine"
    ]
  },

  "visual_style": {
    "perspective": "first_person_pov",
    "camera_style": [
      "head mounted",
      "human eye perspective",
      "slow cinematic movement"
    ],

    "lighting": [
      "warm cinematic",
      "soft natural light",
      "foggy atmosphere",
      "golden hour"
    ],

    "color_palette": [
      "muted vintage",
      "earth tones",
      "soft shadows",
      "desaturated realism"
    ],

    "image_quality": {
      "realism": "high",
      "detail_level": "high",
      "texture_focus": true
    },

    "composition": {
      "focus": "hands and environment",
      "framing": "immersive close POV",
      "motion_blur": "slight"
    }
  },

  "scene_system": {
    "default_scene_duration": 10,
    "scene_transition": [
      "fade",
      "slow dissolve",
      "cinematic blur"
    ],

    "camera_motion": [
      "slow zoom",
      "slight handheld movement",
      "slow pan",
      "depth parallax"
    ]
  },

  "image_prompt_rules": {
    "must_include": [
      "first person POV",
      "cinematic lighting",
      "high realism",
      "immersive environment",
      "detailed textures"
    ],

    "avoid": [
      "anime",
      "cartoon",
      "oversaturated colors",
      "third person perspective",
      "low detail"
    ]
  },

  "voice_style": {
    "gender": "neutral",
    "emotion": "calm reflective",
    "speed": "slow",
    "delivery": "soft cinematic storytelling"
  },

  "music_style": {
    "genres": [
      "ambient",
      "cinematic",
      "soft piano",
      "atmospheric drones"
    ],

    "volume_level": "low",
    "purpose": "support immersion without overpowering narration"
  },

  "subtitle_style": {
    "font": "cinematic sans serif",
    "animation": "fade in",
    "position": "bottom center",
    "style": "minimal"
  },

  "thumbnail_style": {
    "composition": "single focused subject",
    "text_amount": "minimal",
    "emotion": "curiosity and mystery",
    "colors": "warm muted tones",
    "focus_objects": [
      "hands",
      "tools",
      "objects from profession",
      "environment details"
    ]
  },

  "generation_rules": {
    "maintain_character_consistency": true,
    "maintain_lighting_consistency": true,
    "avoid_fast_cuts": true,
    "avoid_excessive_action": true,
    "focus_on_daily_life": true,
    "focus_on_environmental_storytelling": true
  },

  "recommended_models": {
    "llm": [
      "llama3",
      "deepseek-chat",
      "mixtral"
    ],

    "image_generation": [
      "sdxl",
      "flux",
      "realvisxl"
    ],

    "voice": [
      "coqui",
      "piper"
    ]
  }
}